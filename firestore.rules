rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /favorites/{shoeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /cart/{shoeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /products/{productId} {
      allow read, write: if true;
    }
  }
}
