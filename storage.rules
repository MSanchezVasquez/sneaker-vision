rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Carpeta donde el panel de Admin sube las fotos de productos.
    // Lectura pública: necesaria para que el catálogo muestre las imágenes
    // a cualquier visitante de la tienda.
    // Escritura pública: igual que tus reglas actuales de Firestore para
    // /products (allow read, write: if true), consistente con que el panel
    // de Admin de esta app todavía no tiene autenticación propia.
    // Si más adelante agregas login de administrador, cambia esta línea a
    // algo como: allow write: if request.auth != null;
    match /products/{fileName} {
      allow read, write: if true;
    }
  }
}
